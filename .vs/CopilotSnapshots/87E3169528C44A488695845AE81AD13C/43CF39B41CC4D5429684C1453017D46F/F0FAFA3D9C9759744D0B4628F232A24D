@model IEnumerable<SportsStore.Domain.Product>

<div class="container mt-4">
    <h1 class="mb-4">Sports Store Products</h1>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var p in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        @if (!string.IsNullOrEmpty(p.ImageUrl))
                        {
                            <img src="@p.ImageUrl" class="card-img-top" alt="@p.Name" style="height: 250px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 250px;">
                                <span>No Image</span>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@p.Name</h5>

                            <p class="card-text text-muted small">
                                <strong>Category:</strong> @p.Category
                            </p>

                            <p class="card-text">@p.Description</p>

                            <div class="mt-auto">
                                <p class="h5 text-primary mb-3">
                                    @p.Price.ToString("C")
                                </p>

                                <button class="btn btn-primary w-100">
                                    Add to Cart
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info" role="alert">
            No products available at the moment.
        </div>
    }
</div>